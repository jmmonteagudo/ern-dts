{
  "extends": "eslint:recommended",
  "env": {
    "es2022": true,
    "node": true,
    "jest": true,
    "mocha": true
  },
  "globals": {
    "SELECT": true,
    "INSERT": true,
    "UPSERT": true,
    "UPDATE": true,
    "DELETE": true,
    "CREATE": true,
    "DROP": true,
    "CDL": true,
    "CQL": true,
    "CXL": true,
    "cds": true,
    "sap": true,
    "browser": true,
    "$": true,
    "expect": true,
    "QUnit": true
  },
  "rules": {
    "no-console": "off",
    "require-atomic-updates": "off",
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }]
  },
  "overrides": [
    {
      "files": ["app/**/*.js"],
      "env": { "browser": true, "node": false },
      "globals": { "sap": true, "QUnit": true }
    }
  ]
}
