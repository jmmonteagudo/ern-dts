{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ern.sap/events/sap.ern.stock.critical.v1.json",
  "title": "StockCritical",
  "description": "Emitted when a Product reaches stockCriticality === 1 (stock=0) — actionable signal for replenishment workflow.",
  "type": "object",
  "required": [
    "specversion",
    "type",
    "source",
    "id",
    "time",
    "data"
  ],
  "properties": {
    "specversion": {
      "const": "1.0"
    },
    "type": {
      "const": "sap.ern.stock.critical.v1"
    },
    "source": {
      "type": "string"
    },
    "subject": {
      "type": "string",
      "pattern": "^products/"
    },
    "id": {
      "type": "string"
    },
    "time": {
      "type": "string",
      "format": "date-time"
    },
    "datacontenttype": {
      "const": "application/json"
    },
    "data": {
      "type": "object",
      "required": [
        "ID",
        "stock",
        "criticality"
      ],
      "properties": {
        "ID": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "stock": {
          "const": 0
        },
        "criticality": {
          "const": 1
        },
        "trigger": {
          "type": "string",
          "enum": [
            "create",
            "update",
            "auto-detect"
          ]
        }
      }
    },
    "xmock": {
      "type": "boolean",
      "description": "True when emitted by mock event bus."
    },
    "xprovider": {
      "type": "string",
      "description": "Provider id (e.g. mock, eventmesh)."
    }
  }
}
