{
  "name": "ern-dts",
  "version": "1.0.0",
  "description": "Ern (CIS_DTS edition) — Enterprise CI/CD & Quality Platform for SAP BTP, deployed on corporate eu10",
  "repository": "https://github.com/jmmonteagudo/ern-dts",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@cap-js/sqlite": "^1",
    "@sap/cds": "^8",
    "express": "^4"
  },
  "devDependencies": {
    "@sap/cds-dk": "^8",
    "eslint": "^8",
    "puppeteer": "^22"
  },
  "scripts": {
    "start": "cds-serve",
    "watch": "cds watch",
    "lint": "npx eslint .",
    "test:ui": "node scripts/run-qunit-tests.js"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "sqlite",
        "credentials": {
          "url": ":memory:"
        },
        "impl": "@cap-js/sqlite",
        "[production]": {
          "kind": "sqlite",
          "credentials": {
            "url": ":memory:"
          },
          "impl": "@cap-js/sqlite"
        }
      },
      "auth": {
        "kind": "dummy"
      }
    },
    "build": {
      "tasks": [
        {
          "for": "node-cf",
          "src": "srv",
          "options": {
            "model": [
              "srv",
              "db",
              "app"
            ]
          }
        }
      ]
    }
  }
}