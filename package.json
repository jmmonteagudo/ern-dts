{
  "name": "ern-dts",
  "version": "1.0.0",
  "description": "Ern (CIS_DTS edition) — Enterprise CI/CD & Quality Platform for SAP BTP, deployed on corporate eu10",
  "repository": "https://github.com/jmmonteagudo/ern-dts",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@cap-js/sqlite": "^1",
    "@sap/cds": "^7",
    "express": "^4"
  },
  "devDependencies": {
    "@sap/cds-dk": "^7",
    "@wdio/cli": "^8",
    "@wdio/local-runner": "^8",
    "@wdio/mocha-framework": "^8",
    "@wdio/spec-reporter": "^8",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "axios": "^1",
    "eslint": "^8",
    "jest": "^29",
    "wait-on": "^7",
    "wdio-ui5-service": "^2"
  },
  "scripts": {
    "start": "cds-serve",
    "watch": "cds watch",
    "test": "jest --forceExit",
    "test:coverage": "jest --coverage --forceExit",
    "test:e2e": "wdio run test/e2e/wdio.conf.js",
    "test:mocks:atc": "jest test/mocks-atc.test.js --forceExit",
    "test:mocks:events": "jest test/mocks-events.test.js --forceExit",
    "test:mocks:ai": "jest test/mocks-ai.test.js --forceExit",
    "test:mocks": "jest test/mocks-*.test.js --forceExit",
    "test:ui": "jest test/ui-*.test.js --forceExit",
    "lint": "npx eslint ."
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/test/**/*.test.js"
    ]
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "sqlite",
        "credentials": {
          "url": ":memory:"
        },
        "impl": "@cap-js/sqlite",
        "[production]": {
          "kind": "sqlite",
          "credentials": {
            "url": ":memory:"
          },
          "impl": "@cap-js/sqlite"
        }
      },
      "auth": {
        "kind": "dummy"
      }
    },
    "build": {
      "tasks": [
        {
          "for": "node-cf",
          "src": "srv",
          "options": {
            "model": [
              "srv",
              "db",
              "app"
            ]
          }
        }
      ]
    }
  }
}
